{
  "name": "family-meal-planner",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "preview": "npm run build && vite preview",
    "typecheck": "wrangler types --env-interface CloudflareEnvironment && react-router typegen && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test && npm run build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnvironment",
    "seed:test-user": "tsx scripts/seed-local-test-user.ts",
    "gateway:dev": "node --env-file=.env.gateway.local --import tsx gateway/server.ts",
    "gateway:start": "tsx gateway/server.ts",
    "gateway:migrate": "tsx gateway/migrate.ts",
    "gateway:migrate:local": "node --env-file=.env.gateway.local --import tsx gateway/migrate.ts",
    "import": "tsx scripts/import-recipes-mongodb.ts",
    "import:mongodb": "tsx scripts/import-recipes-mongodb.ts",
    "import:sample": "node --env-file=.env.gateway.local --import tsx scripts/import-recipes-mongodb.ts data/recipes_ingredients.csv --database application_local --limit 5000",
    "deploy:preview": "CLOUDFLARE_ENV=preview npm run build && CLOUDFLARE_ENV=preview wrangler deploy",
    "deploy:production": "CLOUDFLARE_ENV=production npm run build && CLOUDFLARE_ENV=production wrangler deploy",
    "postinstall": "wrangler types --env-interface CloudflareEnvironment"
  },
  "dependencies": {
    "@base-ui/react": "latest",
    "@better-auth/infra": "^0.3.7",
    "@modelcontextprotocol/sdk": "latest",
    "@openrouter/sdk": "^0.13.66",
    "agents": "^0.17.4",
    "better-auth": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "commander": "latest",
    "csv-parse": "latest",
    "he": "^1.2.0",
    "isbot": "^5.1.36",
    "lucide-react": "latest",
    "mongodb": "^7.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/he": "^1.2.3",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "latest",
    "tailwindcss": "^4.2.2",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "latest",
    "wrangler": "^4.111.0"
  }
}

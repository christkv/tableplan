TABLEPLAN_PUBLIC_ORIGIN=http://localhost:9090
# For Vite hot reload, change the two origins from localhost:9090 to localhost:5173.
# Production must use the exact public HTTPS origin and activate the prod Spring profile.
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_REDIRECT_URI=http://localhost:9090/login/oauth2/code/google
TABLEPLAN_SESSION_COOKIE_SECURE=false
TABLEPLAN_MONGO_URI=mongodb://127.0.0.1:27017/?replicaSet=rs0
TABLEPLAN_MONGO_DATABASE=application_local
TABLEPLAN_MONGO_MAX_POOL_SIZE=20
TABLEPLAN_VIRTUAL_THREADS=true
TABLEPLAN_DELIVERY_SECRET=
TABLEPLAN_ARTIFACT_DIRECTORY=artifacts
TABLEPLAN_ARTIFACT_MAX_MEGABYTES=10
# TABLEPLAN_ARTIFACT_MODE=s3
# TABLEPLAN_ARTIFACT_BUCKET=
# TABLEPLAN_ARTIFACT_REGION=auto
# TABLEPLAN_ARTIFACT_ENDPOINT=
# TABLEPLAN_ARTIFACT_PATH_STYLE=false
# TABLEPLAN_ARTIFACT_CHUNKED_ENCODING_ENABLED=true
# TABLEPLAN_ARTIFACT_SEND_SSE_HEADER=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
JOBS_ENABLED=true
TABLEPLAN_JOB_CONCURRENCY=2

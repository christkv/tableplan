{
  "extends": "./tsconfig.json",
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "gateway/**/*",
    "scripts/**/*",
    "src/storage/contract.ts",
    "src/domain/**/*",
    "src/domain/quantity/**/*",
    "src/import/**/*",
    "src/ingestion/extract.ts",
    "src/ingestion/types.ts",
    "src/observability/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true
  }
}

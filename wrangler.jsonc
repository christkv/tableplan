{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "family-meal-planner",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "upload_source_maps": true,
  "observability": { "enabled": true },
  "vars": {
    "APP_ENV": "local",
    "LOG_LEVEL": "INFO",
    "BETTER_AUTH_URL": "http://127.0.0.1:5173",
    "BETTER_AUTH_API_TIMEOUT_MS": "10000",
    "PUBLIC_APP_URL": "http://127.0.0.1:5173",
    "PDF_MODE": "html-preview",
    "EMAIL_MODE": "capture",
    "EMAIL_FROM": "Tableplan <shopping@meal-planner.example.com>",
    "RECIPE_EXTRACTION_PROVIDER": "local",
    "OPENROUTER_TEXT_MODEL": "nvidia/nemotron-3-ultra-550b-a55b:free",
    "OPENROUTER_TEXT_FALLBACK_MODELS": "",
    "OPENROUTER_VISION_MODEL": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free",
    "OPENROUTER_VISION_FALLBACK_MODELS": "",
    "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
    "OPENROUTER_APP_TITLE": "Tableplan"
  },
  "ai": { "binding": "AI" },
  "browser": { "binding": "BROWSER" },
  "send_email": [{ "name": "EMAIL" }],
  "queues": {
    "producers": [{ "binding": "EMAIL_DELIVERY_QUEUE", "queue": "tableplan-email-local" }],
    "consumers": [{ "queue": "tableplan-email-local", "max_batch_size": 5, "max_retries": 3, "dead_letter_queue": "tableplan-email-local-dlq" }]
  },
  "r2_buckets": [
    { "binding": "PRIVATE_RECIPE_ASSETS", "bucket_name": "meal-planner-private-recipes-local" }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "RECIPE_INGESTION_AGENT", "class_name": "RecipeIngestionAgent" },
      { "name": "AUTH_SESSION_STORE", "class_name": "AuthSessionStoreDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RecipeIngestionAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["AuthSessionStoreDO"] }
  ],
  "workflows": [
    { "binding": "RECIPE_INGESTION_WORKFLOW", "name": "recipe-ingestion-local", "class_name": "RecipeIngestionWorkflow" }
  ],
  "env": {
    "preview": {
      "name": "family-meal-planner-preview",
      "vars": {
        "APP_ENV": "preview",
        "LOG_LEVEL": "INFO",
        "BETTER_AUTH_URL": "https://family-meal-planner-preview.christkv.workers.dev",
        "BETTER_AUTH_API_TIMEOUT_MS": "10000",
        "PUBLIC_APP_URL": "https://family-meal-planner-preview.christkv.workers.dev",
        "PDF_MODE": "cloud",
        "EMAIL_MODE": "cloud",
        "EMAIL_FROM": "Tableplan <shopping@meal-planner.example.com>",
        "RECIPE_EXTRACTION_PROVIDER": "openrouter",
        "OPENROUTER_TEXT_MODEL": "nvidia/nemotron-3-ultra-550b-a55b:free",
        "OPENROUTER_TEXT_FALLBACK_MODELS": "",
        "OPENROUTER_VISION_MODEL": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free",
        "OPENROUTER_VISION_FALLBACK_MODELS": "",
        "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
        "OPENROUTER_APP_TITLE": "Tableplan"
      },
      "ai": { "binding": "AI" },
      "browser": { "binding": "BROWSER" },
      "send_email": [{ "name": "EMAIL", "allowed_sender_addresses": ["shopping@meal-planner.example.com"] }],
      "queues": {
        "producers": [{ "binding": "EMAIL_DELIVERY_QUEUE", "queue": "tableplan-email-preview" }],
        "consumers": [{ "queue": "tableplan-email-preview", "max_batch_size": 5, "max_retries": 3, "dead_letter_queue": "tableplan-email-preview-dlq" }]
      },
      "r2_buckets": [
        { "binding": "PRIVATE_RECIPE_ASSETS", "bucket_name": "meal-planner-private-recipes-preview" }
      ],
      "services": [
        { "binding": "MONGODB_GATEWAY", "service": "tableplan-mongodb-operations-preview", "remote": true }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "RECIPE_INGESTION_AGENT", "class_name": "RecipeIngestionAgent" },
          { "name": "AUTH_SESSION_STORE", "class_name": "AuthSessionStoreDO" }
        ]
      },
      "workflows": [
        { "binding": "RECIPE_INGESTION_WORKFLOW", "name": "recipe-ingestion-preview", "class_name": "RecipeIngestionWorkflow" }
      ],
    },
    "production": {
      "name": "family-meal-planner",
      "vars": {
        "APP_ENV": "production",
        "LOG_LEVEL": "INFO",
        "BETTER_AUTH_URL": "https://meal-planner.example.com",
        "BETTER_AUTH_API_TIMEOUT_MS": "10000",
        "PUBLIC_APP_URL": "https://meal-planner.example.com",
        "PDF_MODE": "cloud",
        "EMAIL_MODE": "cloud",
        "EMAIL_FROM": "Tableplan <shopping@meal-planner.example.com>",
        "RECIPE_EXTRACTION_PROVIDER": "openrouter",
        "OPENROUTER_TEXT_MODEL": "nvidia/nemotron-3-ultra-550b-a55b:free",
        "OPENROUTER_TEXT_FALLBACK_MODELS": "",
        "OPENROUTER_VISION_MODEL": "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free",
        "OPENROUTER_VISION_FALLBACK_MODELS": "",
        "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
        "OPENROUTER_APP_TITLE": "Tableplan"
      },
      "ai": { "binding": "AI" },
      "browser": { "binding": "BROWSER" },
      "send_email": [{ "name": "EMAIL", "allowed_sender_addresses": ["shopping@meal-planner.example.com"] }],
      "queues": {
        "producers": [{ "binding": "EMAIL_DELIVERY_QUEUE", "queue": "tableplan-email-production" }],
        "consumers": [{ "queue": "tableplan-email-production", "max_batch_size": 5, "max_retries": 3, "dead_letter_queue": "tableplan-email-production-dlq" }]
      },
      "r2_buckets": [
        { "binding": "PRIVATE_RECIPE_ASSETS", "bucket_name": "meal-planner-private-recipes-production" }
      ],
      "services": [
        { "binding": "MONGODB_GATEWAY", "service": "tableplan-mongodb-operations-production", "remote": true }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "RECIPE_INGESTION_AGENT", "class_name": "RecipeIngestionAgent" },
          { "name": "AUTH_SESSION_STORE", "class_name": "AuthSessionStoreDO" }
        ]
      },
      "workflows": [
        { "binding": "RECIPE_INGESTION_WORKFLOW", "name": "recipe-ingestion-production", "class_name": "RecipeIngestionWorkflow" }
      ],
    }
  }
}
